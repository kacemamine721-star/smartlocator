<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.Project_Mobile" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/teal_500</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/blue_900</item>
        <item name="colorOnPrimaryContainer">@color/white</item>
        <item name="colorSecondary">@color/blue_900</item>
        <item name="colorSurface">@color/surface_light</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceContainer">@color/white</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>

    <style name="Theme.Project_Mobile" parent="Base.Theme.Project_Mobile" />

    <style name="DarkSpinnerTheme" parent="ThemeOverlay.Material3.Dark">
        <item name="android:textColor">@color/white</item>
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">@color/white</item>
        <item name="android:spinnerItemStyle">@style/DarkSpinnerItemStyle</item>
    </style>

    <style name="DarkSpinnerItemStyle" parent="Widget.AppCompat.TextView.SpinnerItem">
        <item name="android:textColor">@color/white</item>
    </style>
</resources>
