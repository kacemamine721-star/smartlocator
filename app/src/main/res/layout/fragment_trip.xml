<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/zid_black"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="44dp"
        android:paddingEnd="20dp"
        android:paddingBottom="128dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/trip_planner"
            android:textColor="@color/zid_text_primary"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/trip_vehicle_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/zid_text_secondary"
            android:textSize="15sp"
            tools:text="Kia EV3 - 390 km WLTP - CCS2" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:background="@drawable/bg_panel_surface"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/from"
                android:textColor="@color/zid_text_secondary"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_search_surface"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="@string/current_location"
                android:textColor="@color/zid_text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/to"
                android:textColor="@color/zid_text_secondary"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/trip_destination_input"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_search_surface"
                android:hint="@string/destination_hint"
                android:inputType="textCapWords"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="@color/zid_text_primary"
                android:textColorHint="@color/zid_text_secondary" />

            <TextView
                android:id="@+id/trip_soc_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="@string/battery_percent"
                android:textColor="@color/zid_teal"
                android:textSize="18sp"
                android:textStyle="bold" />

            <SeekBar
                android:id="@+id/trip_soc_seekbar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="65" />

            <Button
                android:id="@+id/btn_plan_trip"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_cta_gradient"
                android:text="@string/plan_route"
                android:textAllCaps="false"
                android:textColor="@color/zid_black"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/trip_result_panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_panel_surface"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/trip_result_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/ready_to_plan"
                android:textColor="@color/zid_text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/trip_result_body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/trip_intro"
                android:textColor="@color/zid_text_secondary"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/trip_stop_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_action_chip_dark"
                android:padding="14dp"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                android:visibility="gone"
                tools:text="Suggested stop: Shell Ben Arous - 50 kW DC - about 18 min" />

            <Button
                android:id="@+id/btn_trip_open_map"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_outline_teal"
                android:text="@string/open_stop_on_map"
                android:textAllCaps="false"
                android:textColor="@color/zid_teal"
                android:textStyle="bold"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
