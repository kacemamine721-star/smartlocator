<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/zid_black"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/add_station_toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/zid_surface"
        app:title="@string/contribute_station"
        app:titleTextColor="@color/zid_text_primary"
        app:navigationIcon="@android:drawable/ic_menu_close_clear_cancel" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/location_details"
                android:textColor="@color/zid_text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                
                <TextView
                    android:id="@+id/add_station_coords"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_panel_surface"
                    android:padding="16dp"
                    android:text="@string/coordinates_placeholder"
                    android:textColor="@color/zid_text_secondary"
                    android:textSize="14sp" />
                    
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_select_on_map"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="@string/action_locate"
                    android:textColor="@color/zid_text_primary"
                    app:strokeColor="@color/zid_teal" />
            </LinearLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:hint="@string/station_name_optional"
                app:hintTextColor="@color/zid_teal"
                app:boxBackgroundColor="@color/zid_surface_2"
                app:boxStrokeColor="@color/zid_teal">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/add_station_name_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/zid_text_primary" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/charging_speed"
                android:textColor="@color/zid_text_primary"
                android:textSize="16sp" />

            <Spinner
                android:id="@+id/add_station_speed_spinner"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:theme="@style/DarkSpinnerTheme"
                android:background="@drawable/bg_panel_surface"
                android:padding="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/current_status"
                android:textColor="@color/zid_text_primary"
                android:textSize="16sp" />

            <Spinner
                android:id="@+id/add_station_status_spinner"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:theme="@style/DarkSpinnerTheme"
                android:background="@drawable/bg_panel_surface"
                android:padding="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_submit_contribution"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="32dp"
                android:text="@string/action_submit_review"
                android:textColor="@color/zid_black"
                app:backgroundTint="@color/zid_teal"
                app:cornerRadius="12dp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
