<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/zid_black"
    android:clipToPadding="false"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingTop="42dp"
    android:paddingEnd="20dp"
    android:paddingBottom="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_gold_badge"
        android:paddingStart="12dp"
        android:paddingTop="7dp"
        android:paddingEnd="12dp"
        android:paddingBottom="7dp"
        android:text="@string/step_vehicle"
        android:textColor="@color/zid_gold"
        android:textSize="12sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:text="@string/choose_ev"
        android:textColor="@color/zid_text_primary"
        android:textSize="32sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/choose_ev_subtitle"
        android:textColor="@color/zid_text_secondary"
        android:textSize="15sp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_ev_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="22dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="12dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_confirm_ev"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="12dp"
        android:text="@string/confirm_selection"
        android:textAllCaps="false"
        android:textColor="@color/zid_black"
        android:textStyle="bold"
        android:enabled="false"
        app:backgroundTint="@color/zid_teal"
        app:cornerRadius="12dp" />

    <TextView
        android:id="@+id/tv_skip"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center"
        android:text="@string/skip_add_later"
        android:textColor="@color/zid_text_secondary"
        android:textSize="15sp"
        android:textStyle="bold" />
</LinearLayout>
