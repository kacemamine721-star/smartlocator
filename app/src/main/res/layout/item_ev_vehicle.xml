<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Plug Icon (Top Left) -->
        <ImageView
            android:id="@+id/iv_plug_icon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_car_charging"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Vehicle Image -->
        <ImageView
            android:id="@+id/iv_ev_image"
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:layout_marginTop="8dp"
            android:scaleType="fitCenter"
            app:layout_constraintTop_toBottomOf="@id/iv_plug_icon"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Brand Text (Centered) -->
        <TextView
            android:id="@+id/tv_ev_brand"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="@color/teal_500"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/iv_ev_image"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Model Text (Centered) -->
        <TextView
            android:id="@+id/tv_ev_model"
            android:layout_width="0dp"
            android:layout_height="15dp"
            android:layout_marginTop="2dp"
            android:gravity="center"
            android:textColor="#577086"
            android:textSize="14sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_ev_brand" />

        <!-- Selected Indicator (Keep hidden by default) -->
        <ImageView
            android:id="@+id/iv_ev_selected"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:visibility="gone"
            android:src="@android:drawable/ic_menu_edit"
            app:tint="@color/teal_500"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>
