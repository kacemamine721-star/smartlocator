<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="8dp"
    app:cardBackgroundColor="@color/zid_surface"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_ev_card"
        android:padding="16dp">

        <ImageView
            android:id="@+id/iv_ev_image"
            android:layout_width="118dp"
            android:layout_height="74dp"
            android:scaleType="fitCenter"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_ev_brand"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:textColor="@color/zid_teal"
            android:textSize="13sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/iv_ev_selected"
            app:layout_constraintStart_toEndOf="@id/iv_ev_image"
            app:layout_constraintTop_toTopOf="@id/iv_ev_image" />

        <TextView
            android:id="@+id/tv_ev_model"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="4dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:textColor="@color/zid_text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/iv_ev_selected"
            app:layout_constraintStart_toEndOf="@id/iv_ev_image"
            app:layout_constraintTop_toBottomOf="@id/tv_ev_brand" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="6dp"
            android:text="Range-aware routing"
            android:textColor="@color/zid_text_secondary"
            android:textSize="13sp"
            app:layout_constraintEnd_toStartOf="@id/iv_ev_selected"
            app:layout_constraintStart_toEndOf="@id/iv_ev_image"
            app:layout_constraintTop_toBottomOf="@id/tv_ev_model" />

        <ImageView
            android:id="@+id/iv_ev_selected"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_ev_selected"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/zid_teal" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>
